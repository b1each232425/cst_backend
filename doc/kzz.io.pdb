<c:Views>
<o:View Id="o51">
<a:ObjectID>242AAF00-D24A-405A-8D15-45A5B5050891</a:ObjectID>
<a:Name>v_param</a:Name>
<a:Code>v_param</a:Code>
<a:CreationDate>1558316371</a:CreationDate>
<a:Creator>NUser</a:Creator>
<a:ModificationDate>1558317248</a:ModificationDate>
<a:Modifier>NUser</a:Modifier>
<a:EndScript>drop table if exists t_v_param;
create table t_v_param as select * from v_param;</a:EndScript>
<a:View.SQLQuery>with recursive parent as (
select 
	p.belongto,
	p.id,
	p.name,
	p.data_type,
	p.value,
    p.remark,
    p.status
from t_param p
where belongto=0
union
select 
  child.belongto,
	child.id,
	child.name,
	child.data_type,
	child.value,
    child.remark,
    child.status
from t_param child
join parent on child.belongto=parent.id)
select 
    a.belongto parent_ID,
    b.name parent_Name,
    a.id,
    a.name,
    a.data_type,
    a.value,
    a.remark,
    a.status 
from parent a join t_param b on a.belongto=b.id;</a:View.SQLQuery>
<a:TaggedSQLQuery>select
   p.belongto,
   p.id,
   p.name,
   p.data_type,
   p.value,
   p.remark,
   p.status as child.belongto,
   child.id,
   child.name,
   child.data_type,
   child.value,
   child.remark,
   child.status a.belongto as parent_ID,
   b.name as parent_Name,
   a.id,
   a.name,
   a.data_type,
   a.value,
   a.remark,
   a.status
from
   t_param p t_param child
   join parent on  child.belongto = parent.id parent a
   join [{731DB489-214E-45B1-90E5-3F9C88DDAE92}=t_param] b on  a.belongto = b.id;
where
   [{00417382-76A1-41D2-8508-648035B78699}=belongto] = 0
</a:TaggedSQLQuery>
