<c:Views>
<o:View Id="o1100">
<a:ObjectID>CE512B7F-BDF3-4828-ABCE-983DBD2A55F7</a:ObjectID>
<a:Name>v_xkb_school_layout</a:Name>
<a:Code>v_xkb_school_layout</a:Code>
<a:CreationDate>1575789119</a:CreationDate>
<a:Creator>冷翠崖竹</a:Creator>
<a:ModificationDate>1627361900</a:ModificationDate>
<a:Modifier>NUser</a:Modifier>
<a:Comment>学校/年级/班级配置表</a:Comment>
<a:EndScript>drop table if exists t_v_xkb_school_layout;
create table t_v_xkb_school_layout as select * from v_xkb_school_layout limit 1;</a:EndScript>
<a:View.SQLQuery>select 
  coalesce(s.value,s.name) school,s.id schoolID,s.addi school_addi, 
  coalesce(g.value,g.name) grade,g.id gradeID, g.addi grade_addi,
  coalesce(c.value,c.name) &quot;class&quot;,c.id classID, c.addi class_addi
from t_param c 
join t_param g on c.belongto=g.id
join t_param s on g.belongto=s.id
where s.belongto=12000
order by s.id,g.id,c.id;</a:View.SQLQuery>
<a:TaggedSQLQuery>select
   coalesce(s.value,s.name) school,
   s.id schoolID,
   s.addi school_addi,
   coalesce(g.value,g.name) grade,
   g.id gradeID,
   g.addi grade_addi,
   coalesce(c.value,c.name) &quot;class&quot;,
   c.id classID,
   c.addi class_addi
from
   [{5A8465B6-28FA-486B-99BE-E515389D1AEF}=t_param] c
   join [{5A8465B6-28FA-486B-99BE-E515389D1AEF}=t_param] g on  c.[{ED6A8705-7800-4A79-B28D-542CE135D2F4}=belongto] = g.[{CD72DCFB-EA75-4727-A987-E5B22BE089C2}=id]
   join [{5A8465B6-28FA-486B-99BE-E515389D1AEF}=t_param] s on  g.[{ED6A8705-7800-4A79-B28D-542CE135D2F4}=belongto] = s.[{CD72DCFB-EA75-4727-A987-E5B22BE089C2}=id]
where
   s.[{ED6A8705-7800-4A79-B28D-542CE135D2F4}=belongto] = 12000
order by
   s.[{CD72DCFB-EA75-4727-A987-E5B22BE089C2}=id] ASC,
   g.[{CD72DCFB-EA75-4727-A987-E5B22BE089C2}=id] ASC,
   c.id; ASC
</a:TaggedSQLQuery>
