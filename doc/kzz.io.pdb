   left join [{CE512B7F-BDF3-4828-ABCE-983DBD2A55F7}=v_xkb_school_layout] l on  s.[{F75341D4-3215-4B3B-B7C8-24476C64F083}=category] = l.[{2ECC88FB-9404-4FC2-AC6E-DF827B71132B}=school] and b.[{951FA444-A2C0-4E81-AFE3-CDD51C64870E}=grade] = l.[{003A2D9B-E395-44BD-AF53-7D203036C2ED}=grade] and b.[{0108233E-5F87-4AC6-9291-A30CAB706606}=class] = l.[{CE6F8DA6-A19B-4A40-BEF9-CF9BA3479FFD}=class]</a:TaggedSQLQuery>
