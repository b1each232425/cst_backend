<a:View.SQLQuery> SELECT ei.id AS exam_id,
    ei.name AS exam_name,
    ei.type AS exam_type,
    ets.exam_session_id,
    ets.total_score,
    es.start_time,
    es.end_time,
    es.mark_mode,
    ep.id AS exam_paper_id,
    ep.name AS paper_name
   FROM t_exam_info ei
     JOIN v_student_exam_total_score ets ON ei.id = ets.exam_id
     LEFT JOIN t_exam_session es ON es.id = ets.exam_session_id
     LEFT JOIN t_exam_paper ep ON ep.exam_session_id = ets.exam_session_id;</a:View.SQLQuery>
