<o:View Id="o3112">
<a:ObjectID>4612EC4F-E7C2-40F9-9457-69C9342750C8</a:ObjectID>
<a:Name>v_student_answer_question</a:Name>
<a:Code>v_student_answer_question</a:Code>
<a:CreationDate>1753948214</a:CreationDate>
<a:Creator>Zpekii</a:Creator>
<a:ModificationDate>1753948215</a:ModificationDate>
<a:Modifier>Zpekii</a:Modifier>
<a:Comment>考试/练习-学生作答题目视图</a:Comment>
<a:EndScript>drop table if exists t_v_student_answer_question;

create table t_v_student_answer_question as select * from v_student_answer_question;</a:EndScript>
<a:View.SQLQuery>SELECT p.exam_session_id,
       p.practice_id,
       q.id  AS question_id,
       q.&quot;order&quot;,
       q.type,
       sa.answer,
       sa.answer_score,
       sa.actual_answers,
       sa.actual_options,
       e.id  AS examinee_id,
       ps.id AS practice_submission_id
FROM t_student_answers sa
         LEFT JOIN t_examinee e ON e.id = sa.examinee_id
         LEFT JOIN t_practice_submissions ps ON ps.id = sa.practice_submission_id
         JOIN t_exam_paper p ON p.exam_session_id = e.exam_session_id OR p.practice_id = ps.practice_id
         JOIN t_paper_group pg ON pg.paper_id = p.id
         JOIN t_exam_paper_question q ON q.group_id = p.id
WHERE e.status::text = &#39;10&#39;::text
   OR ps.status::text &lt;&gt; &#39;04&#39;::text;</a:View.SQLQuery>
<a:TaggedSQLQuery>select p.exam_session_id,
       p.practice_id,
       q.id  as question_id,
       q.&quot;order&quot;,
       q.type,
       sa.answer,
       sa.answer_score,
       sa.actual_answers,
       sa.actual_options,
       e.id  as examinee_id,
       ps.id as practice_submission_id
from [{480D589B-C471-418D-9A14-F69DEDDF1777}=t_student_answers] sa
         LEFT JOIN [{131BAB2F-C6C5-4D6F-A37D-CE5E26A0D332}=t_examinee] e on e.[{8010CF8B-921F-45ED-B921-65D01A7C345D}=id] = sa.[{B3B7AEC3-0147-474C-8B77-42A78F509AEB}=examinee_id]
         LEFT JOIN [{001D64DC-4482-4769-BB38-330357BD47F2}=t_practice_submissions] ps on ps.[{F21DC6DC-9CB5-491E-8173-F373758D8273}=id] = sa.[{3D613FF6-A8F5-45C0-86B8-AE95040B7C9F}=practice_submission_id]
         JOIN [{AF01BEA8-7472-47A7-901E-1DF681904316}=t_exam_paper] p on p.[{7FACFCBA-3408-4DFB-B53D-B691711AD8F0}=exam_session_id] = e.[{244CE7A6-81D7-4EFC-9C71-B437AFD089FF}=exam_session_id] OR p.[{0E364668-3037-4EB3-8330-1F977DD78CEB}=practice_id] = ps.practice_id
         JOIN [{E6A332F6-A8A7-4C04-9E41-6BF4D6D5E545}=t_paper_group] pg on pg.[{9609D5CE-2E70-41FC-8F9E-CD55F4932F9E}=paper_id] = p.[{479ECD3E-12FD-4342-AFD8-49FCB7968BC9}=id]
         JOIN [{535B31A3-EF56-45FE-9F2C-01887FEB8639}=t_exam_paper_question] q on q.[{0CC2F00B-DAFC-4BE0-A131-EE86F0AAC783}=group_id] = p.[{479ECD3E-12FD-4342-AFD8-49FCB7968BC9}=id]
where e.status::text = &#39;10&#39;::text
   OR ps.status::text &lt;&gt; &#39;04&#39;::text;</a:TaggedSQLQuery>
