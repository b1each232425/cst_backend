   [{3C686721-41D1-41DD-8018-FC08458FBB5D}=attach_update_time] update_time,
   [{C06DF4D9-F7A1-4EED-BE9C-5D584DA2FC1B}=attach_creator] creator
from
   [{EE4DFA3A-D17F-4951-92B0-8BDAD7AFAD06}=v_insurance_policy]
where
   [{1CD19FB8-E0D6-402E-B6E9-B39AD7B9E6EF}=insurance_type_id] = 10040
   and [{D02CBC1E-B9DD-4C2E-95FA-C6D38B0F2581}=charge_mode] != &#39;8&#39;
group by
   [{C0870C87-AC17-4DF6-AF73-8E3AB3523B4E}=insure_attach_id],
