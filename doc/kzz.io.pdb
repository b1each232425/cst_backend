<o:View Id="o74">
<a:ObjectID>59EA296F-3BD9-4C0F-BFE3-E0CDEBA1D35D</a:ObjectID>
<a:Name>v_api_domain</a:Name>
<a:Code>v_api_domain</a:Code>
<a:CreationDate>1583151011</a:CreationDate>
<a:Creator>NUser</a:Creator>
<a:ModificationDate>1615087109</a:ModificationDate>
<a:Modifier>NUser</a:Modifier>
<a:Comment>api domain</a:Comment>
<a:EndScript>drop table if exists t_v_api_domain;
create table if not exists t_v_api_domain as select * from v_api_domain;</a:EndScript>
<a:View.SQLQuery>select a.id,
a.id as api_id,a.name as api_name,a.expose_path,
d.id as domain_id, d.name as domain_name,d.priority,
da.grant_source,da.data_access_mode,da.data_scope
from t_api a
left join t_domain_api da on da.api=a.id
left join t_domain d on da.domain=d.id
order by a.id,da.id</a:View.SQLQuery>
<a:TaggedSQLQuery>select
   a.id,
   a.id as api_id,
   a.name as api_name,
   a.expose_path,
   d.id as domain_id,
   d.name as domain_name,
   d.priority,
   da.grant_source,
   da.data_access_mode,
   da.data_scope
from
   [{9AC1CCFD-A09D-41D4-A251-9357CCBC3D0E}=t_api] a
   left join [{B8CEC14A-6240-4571-9362-7E1E33D8A5E7}=t_domain_api] da on  da.[{8DA7C15F-5F8A-4E80-A99C-4D7C874DFCF9}=api] = a.[{F3F9853C-2345-4E21-A5B4-B17CF463A232}=id]
   left join [{1734E784-C560-40F1-ACEE-9AE71B0E7F21}=t_domain] d on  da.[{9BF70009-C8F0-4B07-BB3A-C3028E93184F}=domain] = d.[{9BD3BBC5-7CEB-4F80-BA22-64E543926467}=id]
order by
   a.[{F3F9853C-2345-4E21-A5B4-B17CF463A232}=id] ASC,
   da.[{26C37AAD-90D9-4F2C-BA1B-1EA78CEAD032}=id] ASC
</a:TaggedSQLQuery>
