<o:View Id="o3038">
<a:ObjectID>7241D126-B310-4EA0-9BFA-C3BB293C5A08</a:ObjectID>
<a:Name>v_student_practice_total_score</a:Name>
<a:Code>v_student_practice_total_score</a:Code>
<a:CreationDate>1753948214</a:CreationDate>
<a:Creator>Zpekii</a:Creator>
<a:ModificationDate>1754641559</a:ModificationDate>
<a:Modifier>wzsaber</a:Modifier>
<a:Comment>展示学生练习成绩视图                      </a:Comment>
<a:EndScript>drop table if exists t_v_student_practice_total_score;
create table t_v_student_practice_total_score as select * from v_student_practice_total_score;</a:EndScript>
<a:View.SQLQuery> SELECT DISTINCT ps.id,
    ps.practice_id,
    p.name,
    ps.student_id,
    ps.exam_paper_id,
        CASE
            WHEN bool_or(a.answer_score IS NULL) THEN NULL::double precision
            ELSE sum(a.answer_score)
        END AS total_score,
    p.type,
    ps.attempt,
    ps.status,
    count(
        CASE
            WHEN a.answer_score &lt;&gt; epq.score THEN 1
            ELSE NULL::integer
        END) AS wrong_count,
    (ps.end_time - ps.start_time) AS used_time
   FROM t_practice_submissions ps
     JOIN t_student_answers a ON ps.id = a.practice_submission_id
     JOIN t_exam_paper_question epq ON a.question_id = epq.id
     JOIN t_practice p ON ps.practice_id = p.id
  WHERE ps.status::text = &#39;08&#39;::text
  GROUP BY ps.id, p.id, ps.attempt, ps.student_id, ps.end_time, ps.start_time;</a:View.SQLQuery>
<a:TaggedSQLQuery> select DISTINCT ps.id,
    ps.practice_id,
    p.name,
    ps.student_id,
    ps.exam_paper_id,
        CASE
            WHEN bool_or(a.answer_score IS NULL) THEN NULL::double precision
            ELSE sum(a.answer_score)
        END as total_score,
    p.type,
    ps.attempt,
    ps.status,
    count(
        CASE
            WHEN a.answer_score &lt;&gt; epq.score THEN 1
            ELSE NULL::integer
        END) as wrong_count,
    (ps.end_time - ps.start_time) as used_time
   from [{001D64DC-4482-4769-BB38-330357BD47F2}=t_practice_submissions] ps
     JOIN [{480D589B-C471-418D-9A14-F69DEDDF1777}=t_student_answers] a on ps.[{F21DC6DC-9CB5-491E-8173-F373758D8273}=id] = a.[{3D613FF6-A8F5-45C0-86B8-AE95040B7C9F}=practice_submission_id]
     JOIN [{535B31A3-EF56-45FE-9F2C-01887FEB8639}=t_exam_paper_question] epq on a.[{2447F6F1-742B-4131-B5F1-AAD663488D8E}=question_id] = epq.[{D8C451E9-65E9-43C9-840E-F0C1F0474940}=id]
     JOIN [{F6063EF0-FEE9-4FEC-A10C-5340AC0880B4}=t_practice] p on ps.[{FC48462E-E5EA-4612-B0D0-EB0CA75FF587}=practice_id] = p.[{946B9FDD-6EBD-46E2-9976-AE9FB3BDBF4F}=id]
  where ps.status::text = &#39;08&#39;::text
  group by ps.[{F21DC6DC-9CB5-491E-8173-F373758D8273}=id], p.[{946B9FDD-6EBD-46E2-9976-AE9FB3BDBF4F}=id], ps.[{51EF5966-1B10-498D-931F-DC42088D621B}=attempt], ps.[{97DD3419-F145-4438-888C-83979043FFBD}=student_id], ps.[{0BC68D91-46FD-410C-881A-192E379E79B0}=end_time], ps.start_time;</a:TaggedSQLQuery>
