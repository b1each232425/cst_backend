   da.grant_source as da_grant_source,
   da.data_access_mode as da_data_access_mode,
   ud.id as user_domain_id,
   ud.data_scope-&gt;&gt; &#39;data&#39; as ud_grant_data,
   ud.data_scope-&gt;&gt; &#39;type&#39; as ud_grant_type,
   ud.grant_source as ud_grant_source,
