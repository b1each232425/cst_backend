   (select jsonb_agg(list) from jsonb_array_elements(m.insured_list) as list  where m.insured_list &lt;&gt; &#39;{}&#39; and list-&gt;&gt;&#39;Action&#39;=&#39;update&#39;) as update_insured_list,
