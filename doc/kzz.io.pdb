<o:View Id="o3064">
<a:ObjectID>A0A0BA49-4A34-4D95-9639-DBCCB5B21B4A</a:ObjectID>
<a:Name>v_invigilation_info</a:Name>
<a:Code>v_invigilation_info</a:Code>
<a:CreationDate>1753948214</a:CreationDate>
<a:Creator>Zpekii</a:Creator>
<a:ModificationDate>1754016419</a:ModificationDate>
<a:Modifier>Zpekii</a:Modifier>
<a:Comment>监考视图</a:Comment>
<a:EndScript>drop table if exists t_v_invigilation_info;
create table t_v_invigilation_info as select * from v_invigilation_info;</a:EndScript>
<a:View.SQLQuery> WITH invigilation_statistics AS (
         SELECT examinees.exam_session_id,
            examinees.exam_room AS exam_room_id,
            count(DISTINCT examinees.student_id) AS examinee_num,
            sum(
                CASE
                    WHEN examinees.status::text = &#39;02&#39;::text THEN 1
                    ELSE 0
                END) AS absentee_num,
            sum(
                CASE
                    WHEN examinees.status::text = &#39;06&#39;::text THEN 1
                    ELSE 0
                END) AS cheater_num,
            sum(
                CASE
                    WHEN examinees.status::text = &#39;14&#39;::text THEN 1
                    ELSE 0
                END) AS abnormal_examinee_num,
            sum(
                CASE
                    WHEN examinees.extra_time &gt; 0 THEN 1
                    ELSE 0
                END) AS extended_time_num
           FROM t_examinee examinees
          GROUP BY examinees.exam_session_id, examinees.exam_room
        )
 SELECT array_agg(DISTINCT users.id) AS invigilator_ids,
    array_agg(users.official_name) AS invigilator_names,
    count(invigilations.id) AS invigilator_num,
    exam_infos.id AS exam_id,
    exam_infos.type AS exam_type,
    exam_infos.mode AS exam_mode,
    exam_sessions.id AS exam_session_id,
    exam_sessions.start_time,
    exam_sessions.end_time,
    exam_sessions.status,
    exam_sites.id AS exam_site_id,
    exam_sites.name AS exam_site_name,
    exam_rooms.id AS exam_room_id,
    exam_rooms.name AS exam_room_name,
    exam_rooms.capacity AS exam_room_capacity,
    exam_papers.name AS exam_session_name,
    exam_records.content AS record,
    exam_records.basic_eval,
    invi_stat.examinee_num,
    invi_stat.absentee_num,
    invi_stat.cheater_num,
    invi_stat.abnormal_examinee_num,
    invi_stat.extended_time_num
   FROM t_exam_session exam_sessions
     LEFT JOIN t_invigilation invigilations ON invigilations.exam_session_id = exam_sessions.id
     LEFT JOIN t_exam_room exam_rooms ON invigilations.exam_room = exam_rooms.id
     JOIN t_exam_info exam_infos ON exam_infos.id = exam_sessions.exam_id
     LEFT JOIN t_user users ON users.id = invigilations.invigilator
     LEFT JOIN t_exam_paper exam_papers ON exam_papers.exam_session_id = exam_sessions.id
     LEFT JOIN t_exam_site exam_sites ON exam_sites.id = exam_rooms.exam_site
     LEFT JOIN t_exam_record exam_records ON exam_records.exam_session = invigilations.exam_session_id AND exam_records.exam_room = invigilations.exam_room
     LEFT JOIN invigilation_statistics invi_stat ON invi_stat.exam_session_id = exam_sessions.id AND (exam_infos.mode::text = &#39;00&#39;::text OR exam_infos.mode::text = &#39;02&#39;::text AND invi_stat.exam_room_id = exam_rooms.id)
  GROUP BY exam_sessions.id, exam_infos.id, exam_sites.id, exam_rooms.id, exam_papers.name, exam_records.content, exam_records.basic_eval, invi_stat.examinee_num, invi_stat.absentee_num, invi_stat.cheater_num, invi_stat.abnormal_examinee_num, invi_stat.extended_time_num
  ORDER BY exam_sessions.start_time DESC;</a:View.SQLQuery>
<a:TaggedSQLQuery>select
   examinees.exam_session_id,
   examinees.exam_room as exam_room_id,
   count(distinct examinees.student_id) as examinee_num,
   sum(                 case                     when examinees.status::text = &#39;02&#39;::text then 1                     else 0                 end) as absentee_num,
   sum(                 case                     when examinees.status::text = &#39;06&#39;::text then 1                     else 0                 end) as cheater_num,
   sum(                 case                     when examinees.status::text = &#39;14&#39;::text then 1                     else 0                 end) as abnormal_examinee_num,
   sum(                 case                     when examinees.extra_time &gt; 0 then 1                     else 0                 end) as extended_time_num array_agg (DISTINCT users.id) as invigilator_ids,
   array_agg(users.official_name) as invigilator_names,
   count(invigilations.id) as invigilator_num,
   exam_infos.id as exam_id,
   exam_infos.type as exam_type,
   exam_infos.mode as exam_mode,
   exam_sessions.id as exam_session_id,
   exam_sessions.start_time,
   exam_sessions.end_time,
   exam_sessions.status,
   exam_sites.id as exam_site_id,
   exam_sites.name as exam_site_name,
   exam_rooms.id as exam_room_id,
   exam_rooms.name as exam_room_name,
   exam_rooms.capacity as exam_room_capacity,
   exam_papers.name as exam_session_name,
   exam_records.content as record,
   exam_records.basic_eval,
   invi_stat.examinee_num,
   invi_stat.absentee_num,
   invi_stat.cheater_num,
   invi_stat.abnormal_examinee_num,
   invi_stat.extended_time_num
from
   t_examinee examinees t_exam_session exam_sessions
   LEFT JOIN [{C80DEE7D-7AEC-4D4E-8AD8-ED0FB6556202}=t_invigilation] invigilations on  invigilations.[{E81F97B4-64A0-4C86-BA98-B2473EB1EBAC}=exam_session_id] = exam_sessions.id
   LEFT JOIN [{77A5FCED-3907-4360-8BDE-E7CA3AB8C3DD}=t_exam_room] exam_rooms on  invigilations.[{4ED1134D-98F8-46A5-B729-3133E064D56D}=exam_room] = exam_rooms.[{0DEFD6F3-F2C1-45A4-876E-2C489BDD5A7C}=id]
   JOIN [{8EA43941-8467-4280-A761-6CDAAC4D741A}=t_exam_info] exam_infos on  exam_infos.[{B1D13A91-A4C9-4504-B545-856687C624A5}=id] = exam_sessions.exam_id
   LEFT JOIN [{818DA3CB-F06A-40EA-921A-7B0F56A1BF88}=t_user] users on  users.[{81E1442F-8102-4AA4-9AE3-FA9322DD580F}=id] = invigilations.[{0FDD95A3-C2A6-4105-B952-DF8F367560F0}=invigilator]
   LEFT JOIN [{AF01BEA8-7472-47A7-901E-1DF681904316}=t_exam_paper] exam_papers on  exam_papers.[{7FACFCBA-3408-4DFB-B53D-B691711AD8F0}=exam_session_id] = exam_sessions.id
   LEFT JOIN [{026CF88A-8A37-41BD-8172-6DA9B12ADD33}=t_exam_site] exam_sites on  exam_sites.[{3A3F55F4-7AE0-44F6-9F6A-068B60FA0194}=id] = exam_rooms.[{F5A85785-A765-4EE7-A4E9-D8EE8287EE61}=exam_site]
   LEFT JOIN [{E28BF777-7821-491C-93E3-314D1B8E9EA0}=t_exam_record] exam_records on  exam_records.[{426F4BD3-4503-4045-B54E-55DF41D9C850}=exam_session] = invigilations.[{E81F97B4-64A0-4C86-BA98-B2473EB1EBAC}=exam_session_id] AND exam_records.[{39197150-2EF5-420B-9351-1926C805307E}=exam_room] = invigilations.[{4ED1134D-98F8-46A5-B729-3133E064D56D}=exam_room]
   LEFT JOIN invigilation_statistics invi_stat on  invi_stat.exam_session_id = exam_sessions.id AND ( exam_infos.mode::text = &#39;00&#39;::text OR exam_infos.mode::text = &#39;02&#39;::text AND invi_stat.exam_room_id = exam_rooms.[{0DEFD6F3-F2C1-45A4-876E-2C489BDD5A7C}=id])
group by
   examinees.exam_session_id,
   examinees.exam_room BY exam_sessions.id,
   exam_infos.[{B1D13A91-A4C9-4504-B545-856687C624A5}=id],
   exam_sites.[{3A3F55F4-7AE0-44F6-9F6A-068B60FA0194}=id],
   exam_rooms.[{0DEFD6F3-F2C1-45A4-876E-2C489BDD5A7C}=id],
   exam_papers.[{4C6D82CF-7EE4-416C-B171-FAED73090A5F}=name],
   exam_records.[{0EDB3A34-5D78-4162-8213-C0791869A7D8}=content],
   exam_records.[{A3E0BB66-4A78-4485-922B-EFA58D3F291A}=basic_eval],
   invi_stat.examinee_num,
   invi_stat.absentee_num,
   invi_stat.cheater_num,
   invi_stat.abnormal_examinee_num,
   invi_stat.extended_time_num
order by
   exam_sessions.start_time DESC; ASC
</a:TaggedSQLQuery>
