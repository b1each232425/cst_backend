<o:View Id="o1141">
<a:ObjectID>ED70E671-81D7-4A95-BCF1-DC5F2B438011</a:ObjectID>
<a:Name>v_region</a:Name>
<a:Code>v_region</a:Code>
<a:CreationDate>1579364226</a:CreationDate>
<a:Creator>冷翠崖竹</a:Creator>
<a:ModificationDate>1627361930</a:ModificationDate>
<a:Modifier>NUser</a:Modifier>
<a:EndScript>drop table if exists t_v_region;
create table t_v_region as select * from v_region  limit 1;</a:EndScript>
<a:View.SQLQuery>select
p.region_name province,
c.region_name city,
d.region_name district,
s.region_name street
from t_region p
left join t_region c on c.parent_id=p.id and c.level=4 and c.region_name &lt;&gt;&#39;中山市&#39; and c.region_name&lt;&gt;&#39;东莞市&#39;
left join t_region d on d.parent_id=c.id and d.level=6
left join t_region s on s.parent_id=d.id and s.level=8
where p.parent_id=0
union
select
   &#39;广东省&#39;,
c.region_name city,
null,
s.region_name street
from t_region c
left join t_region s on s.parent_id=c.id and s.level=8
where c.region_name=&#39;中山市&#39; or c.region_name = &#39;东莞市&#39;</a:View.SQLQuery>
<a:TaggedSQLQuery>select
   p.region_name province,
   c.region_name city,
   d.region_name district,
   s.region_name street
from
   [{55FBF3D8-A0BB-49B9-8F6E-E26B67395D35}=t_region] p
   left join [{55FBF3D8-A0BB-49B9-8F6E-E26B67395D35}=t_region] c on  c.[{1B9A0967-91A5-45DD-86B6-F3458CE42D7C}=parent_id] = p.[{FCFC3AFB-67D4-4D5F-8CAB-26FED8E991DB}=id] and c.[{DFD3A813-A259-4881-AEC2-C540CD9E9709}=level] = 4 and c.[{1EFC2422-1687-417D-9C7C-C10FB4310F7C}=region_name] &lt;&gt; &#39;中山市&#39; and c.[{1EFC2422-1687-417D-9C7C-C10FB4310F7C}=region_name] &lt;&gt; &#39;东莞市&#39;
   left join [{55FBF3D8-A0BB-49B9-8F6E-E26B67395D35}=t_region] d on  d.[{1B9A0967-91A5-45DD-86B6-F3458CE42D7C}=parent_id] = c.[{FCFC3AFB-67D4-4D5F-8CAB-26FED8E991DB}=id] and d.[{DFD3A813-A259-4881-AEC2-C540CD9E9709}=level] = 6
   left join [{55FBF3D8-A0BB-49B9-8F6E-E26B67395D35}=t_region] s on  s.[{1B9A0967-91A5-45DD-86B6-F3458CE42D7C}=parent_id] = d.[{FCFC3AFB-67D4-4D5F-8CAB-26FED8E991DB}=id] and s.[{DFD3A813-A259-4881-AEC2-C540CD9E9709}=level] = 8
where
   p.[{1B9A0967-91A5-45DD-86B6-F3458CE42D7C}=parent_id] = 0
order by
   p.[{FCFC3AFB-67D4-4D5F-8CAB-26FED8E991DB}=id] ASC,
   c.[{FCFC3AFB-67D4-4D5F-8CAB-26FED8E991DB}=id] ASC,
   d.id; ASC

union
select
   &#39;广东省&#39;,
   c.[{1EFC2422-1687-417D-9C7C-C10FB4310F7C}=region_name] city,
   null,
   s.region_name street
from
   [{55FBF3D8-A0BB-49B9-8F6E-E26B67395D35}=t_region] c
   left join [{55FBF3D8-A0BB-49B9-8F6E-E26B67395D35}=t_region] s on  s.[{1B9A0967-91A5-45DD-86B6-F3458CE42D7C}=parent_id] = c.[{FCFC3AFB-67D4-4D5F-8CAB-26FED8E991DB}=id] and s.[{DFD3A813-A259-4881-AEC2-C540CD9E9709}=level] = 8
where
   c.[{1EFC2422-1687-417D-9C7C-C10FB4310F7C}=region_name] = &#39;中山市&#39;
   or c.[{1EFC2422-1687-417D-9C7C-C10FB4310F7C}=region_name] = &#39;东莞市&#39;
</a:TaggedSQLQuery>
