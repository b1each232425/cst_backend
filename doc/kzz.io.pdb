<a:Modifier>Zpekii</a:Modifier>
<a:Comment>考试作答人数统计视图</a:Comment>
<a:EndScript>drop table if exists t_v_exam_respondent_count;

create table t_v_exam_respondent_count as select * from v_exam_respondent_count;</a:EndScript>
<a:View.SQLQuery>SELECT es.id                                     AS exam_session_id,
       COALESCE(count(DISTINCT e.id), 0::bigint) AS respondent_count
FROM t_exam_session es
         LEFT JOIN t_examinee e ON es.id = e.exam_session_id AND e.status::text = &#39;10&#39;::text
GROUP BY es.id;</a:View.SQLQuery>
<a:TaggedSQLQuery>select es.id                                     as exam_session_id,
       COALESCE(count(DISTINCT e.id), 0::bigint) as respondent_count
from [{19981BAC-9978-46DF-B74F-ADD3B0CF8137}=t_exam_session] es
         LEFT JOIN [{131BAB2F-C6C5-4D6F-A37D-CE5E26A0D332}=t_examinee] e on es.[{2A3C7F59-31BD-49C6-BDFC-9E105CD82CD1}=id] = e.[{244CE7A6-81D7-4EFC-9C71-B437AFD089FF}=exam_session_id] AND e.status::text = &#39;10&#39;::text
group by es.id;</a:TaggedSQLQuery>
