   left join [{22E73830-9789-4D9D-8E01-BE6590BB8956}=t_user] u on  r.[{FE31FFA5-F047-4C31-9256-58A87DAE2DAD}=insured_id] = u.[{805285D5-5233-43A6-82AE-E90BF3A2F5DC}=id]
