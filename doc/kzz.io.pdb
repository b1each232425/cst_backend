<o:View Id="o103">
<a:ObjectID>2FB69961-F80A-45A1-93E9-3687C01D7FE2</a:ObjectID>
<a:Name>v_domain_asset</a:Name>
<a:Code>v_domain_asset</a:Code>
<a:CreationDate>1721735137</a:CreationDate>
<a:Creator>NUser</a:Creator>
<a:ModificationDate>1721944410</a:ModificationDate>
<a:Modifier>NUser</a:Modifier>
<a:Comment>domain user relation
domain api relation</a:Comment>
<a:EndScript>drop table if exists t_v_domain_asset;
create table if not exists t_v_domain_asset as select * from v_domain_asset limit 1;</a:EndScript>
<a:View.SQLQuery>select 
  d.id,d.name domain_name,d.domain,d.priority,
  da.id domain_asset_id,
  u.id user_id,account,official_name,id_card_type,id_card_no,email,nickname,mobile_phone,u.status user_status,
  coalesce(official_name,nickname,mobile_phone,account,u.id::text) as user_name,
  a.id api_id,a.name api_name,expose_path
from t_domain d
  left join t_domain_asset da on  da.domain_id=d.id
  left join t_api a on r_type=&#39;da&#39; and a.id=asset_id
  left join t_user u on r_type=&#39;ud&#39; and u.id=asset_id
order by d.domain,a.expose_path,u.id</a:View.SQLQuery>
<a:TaggedSQLQuery>select
   d.id,
   d.name as domain_name,
   d.domain,
   d.priority,
   da.id as domain_asset_id,
   u.id as user_id,
   [{F0528ACA-911A-4476-8D30-690CBB329E26}=account],
   [{CC438833-4B0B-4170-8125-9E9127D20AC5}=official_name],
   [{CC02149C-DD00-410E-B92F-660EF3B257D3}=id_card_type],
   [{9C5C86B4-BA46-41A0-A5D4-61BB1C74E15E}=id_card_no],
   [{79B5C2D5-96DC-48EE-B0CB-D8BFF6D7E88F}=email],
   [{42705B71-49F6-4F04-9D0A-E6972ED46EE7}=nickname],
   [{A816E380-9CA7-46BD-8FBD-E3149A5162CB}=mobile_phone],
   u.status as user_status,
   coalesce(official_name,nickname,mobile_phone,account,u.id::text) as user_name,
   a.id as api_id,
   a.name as api_name,
   [{48497E37-F64E-4A87-96E2-97CA0ABE96E2}=expose_path]
from
   [{1734E784-C560-40F1-ACEE-9AE71B0E7F21}=t_domain] d
   left join [{163F5B3E-D48D-47D0-A088-7B1DECD4FC77}=t_domain_asset] da on  da.[{E7935112-BD4F-401A-9FCC-082FA73D32BB}=domain_id] = d.[{9BD3BBC5-7CEB-4F80-BA22-64E543926467}=id]
   left join [{9AC1CCFD-A09D-41D4-A251-9357CCBC3D0E}=t_api] a on  [{1D2D830B-5380-465E-A538-88BA6A2C83DB}=r_type] = &#39;da&#39; and a.[{F3F9853C-2345-4E21-A5B4-B17CF463A232}=id] = [{4571EC44-B3E8-4800-AD38-BDD5A24C39FF}=asset_id]
   left join [{BFAD310B-A050-4D4A-B6CB-66E2916FA987}=t_user] u on  [{1D2D830B-5380-465E-A538-88BA6A2C83DB}=r_type] = &#39;ud&#39; and u.[{35B80EE6-0B1A-456D-BB05-A444ACF4788E}=id] = [{4571EC44-B3E8-4800-AD38-BDD5A24C39FF}=asset_id]
order by
   d.[{F68D867B-41A0-46EF-A28E-10AA15C6772C}=domain] ASC,
   a.[{48497E37-F64E-4A87-96E2-97CA0ABE96E2}=expose_path] ASC,
   u.[{35B80EE6-0B1A-456D-BB05-A444ACF4788E}=id] ASC
</a:TaggedSQLQuery>
