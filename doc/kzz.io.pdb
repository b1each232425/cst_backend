<o:NoteSymbol Id="o6">
<a:Text>{\rtf1\ansi\ansicpg936\deff0\nouicompat\deflang1033\deflangfe2052{\fonttbl{\f0\fnil \&#39;e5\&#39;be\&#39;ae\&#39;e8\&#39;bd\&#39;af\&#39;e9\&#39;9b\&#39;85\&#39;e9\&#39;bb\&#39;91;}{\f1\fswiss Calibri;}}
{\*\generator Riched20 10.0.17763}\viewkind4\uc1 
\pard\f0\fs29\lang2052\u27880?\u24847?\f1\lang1033\par
\f0\lang2052\u12288?\u12288?\f1\lang1033 *** \f0\lang2052\u20219?\u20309?\u24773?\u20917?\u19979?\u-28419?\u19981?\u20801?\u-29768?\f1\lang1033 ***\f0\lang2052\u22312?\u24212?\u29992?\u31243?\u24207?\u20013?\u20351?\u29992?\u31867?\u20284?\f1\lang1033  select * from table_name\f0\lang2052\u-28711?\u31181?\f1\lang1033 sql\f0\lang2052\u-29715?\u21477?\u-244?\u19979?\u-28688?\u30340?\u20860?\u23481?\u19981?\u21253?\u25324?\u-28711?\u31181?\u26041?\u24335?\u12290?\par
\u29256?\u26412?\u21495?\par
\f1\lang1033 m.n.x.y\par
m:\f0\lang2052\u12288?\u31995?\u32479?\u21319?\u32423?\u-244?\u21487?\u-32515?\u19981?\u20860?\u23481?\par
\f1\lang1033 n:\f0\lang2052\u12288?\u28155?\u21152?\u26032?\u21151?\u-32515?\u-244?\u20445?\u25345?\u20860?\u23481?\f1\lang1033\par
x:\f0\lang2052\u12288?\u20026?\u-30616?\f1\lang1033 /\f0\lang2052\u-30266?\u22270?\u28155?\u21152?\u26032?\u23383?\u27573?\u-244?\u20445?\u25345?\u20860?\u23481?\u-244?\u23383?\u27573?\u22312?\u-30616?\u20013?\u30340?\u27425?\u24207?\u-29693?\u25972?\u-244?\u20445?\u25345?\u20860?\u23481?\f1\lang1033\par
y:\f0\lang2052\u12288?\u20462?\u25913?\u21021?\u22987?\u21270?\u25968?\u25454?\u12289?\u20026?\u-30266?\u22270?\u28155?\u21152?\u23383?\u27573?\u12289?\u20462?\u25913?\u-30266?\u22270?\u23383?\u27573?\u23450?\u20041?\u-244?\u20445?\u25345?\u20860?\u23481?\f1\lang1033\par
\f0\lang2052\par
\u20860?\u23481?\u26159?\u25351?\u21069?\u31471?\u12289?\u21518?\u31471?\u20195?\u30721?\u22312?\u19981?\u20462?\u25913?\u30340?\u24773?\u20917?\u19979?\u21487?\u20197?\u27491?\u24120?\u-28720?\u-30644?\u-244?\u19994?\u21153?\u-28613?\u-28783?\u-248?\u21407?\u26469?\u27491?\u30830?\u30340?\u-247?\u19981?\u21464?\u12290?\par
\par
\u21021?\u27425?\u21021?\u22987?\u21270?\u25968?\u25454?\u24211?\u26102?\u-244?\u-29705?\u25353?\u20197?\u19979?\u27969?\u31243?\u22788?\u29702?(\par
\f1\lang1033       \f0\lang2052\u-24901?\u28902?\u30340?\u21407?\u22240?\u26159?c_mobile_region, t_region \u30340?\par
\f1\lang1033       \f0\lang2052\u21021?\u22987?\u21270?\u25968?\u25454?\u20026?30MB\u24038?\u21491?\u-244?powerDesigner\u22788?\u29702?\u19981?\u20102?\f1\lang1033 )\f0\lang2052\par
\par
1\u12289?\u25191?\u-30644?create table if not exists c_mobile_region(\par
\tab id serial primary key,\par
\tab prefix char(7),\par
\tab province varchar(16),\par
\tab city varchar(16),\par
\tab name varchar(16),\par
\tab provider varchar(32))\par
\par
2\u12289?\u25191?\u-30644?cmd/mobile_region.sql\par
\par
3\u12289?\u29983?\u25104?\u29983?\u29702?\u27169?\u22411?\u26102?\u-29705?\u21253?\u21547?t_region(\u-24872?\u-29788?\u19981?\u21253?\u21547?)\par
\par
4\u12289?\u-28720?\u-30644?\u-26503?\u30446?doc/t_region_init.sql\par
\par
}
</a:Text>
