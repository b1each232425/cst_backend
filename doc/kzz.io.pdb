   x.[{67F040BA-82B6-4B82-BE88-E3EB6CD13EE5}=Faculty],
   x.[{951FA444-A2C0-4E81-AFE3-CDD51C64870E}=Grade],
   x.[{0108233E-5F87-4AC6-9291-A30CAB706606}=Class],
   x.[{A43B6607-4821-4F17-95CA-B09CC5EED05C}=Create_Time] as x_Create_Time,
   s.[{20B3A19E-9499-4582-B88C-4D5D79AAA5F6}=Name] as school,
   s.[{F60BB9F7-02BF-4822-AAD1-DB999427F1BE}=Faculty] as s_Faculty,
   s.[{F52C529E-88E9-4A5C-BDE4-F5468E630453}=Branches] as s_Branches,
   s.[{F75341D4-3215-4B3B-B7C8-24476C64F083}=Category] as s_Category,
   s.[{AF71AD02-4DCA-43CA-9492-BB35C832856A}=Province],
   s.[{F6844D3F-D11A-4202-B74A-8A2F018CD1CA}=City],
   s.[{31F98DC5-4EE3-4991-A4C6-C4E14E765C19}=District],
   s.[{6D5B522E-AA52-4D7B-8189-D104E16A3CCE}=Data_Sync_Target],
   s.[{9856DE36-B02A-479A-8E35-2DE2B407BECD}=Sale_Managers],
   s.[{00AC7A5A-5AC6-4813-AC92-17CA8616CC84}=School_Managers],
   s.[{6F7194EE-60B3-4960-9862-E986CA8C35F8}=purchase_rule],
   s.[{21FE171B-1D85-44A4-BE15-CB20874D1324}=Create_Time] as s_Create_Time,
   it.[{21FC536F-84E9-4614-8720-0557493E936D}=parent_id] as insurance_type_parent_id,
   a.[{72C77725-F44C-48A0-A618-1443B085C8CB}=id] as insure_attach_id,
   a.[{81E488DA-7E3B-42B6-9928-1DB09065214B}=policy_no],
   a.[{CAB6747B-EE2A-41D2-A087-65AF3F199980}=others],
   a.[{1C49A524-EEEA-4010-8D79-89E2486242E2}=files],
   a.[{D0C6F46E-AD0B-4C47-A57E-EA416DAE5DA6}=addi] as attach_addi,
   a.[{44DEEA2D-4350-4A49-B0F9-34B9888F1AC8}=create_time] as attach_create_time,
   a.[{E9F07633-88E3-4CFB-A45C-7FE63838FB48}=update_time] as attach_update_time,
   a.[{52B2452C-DAE3-47C4-9BA5-305275B19B53}=creator] as attach_creator,
   (SELECT CASE WHEN a.files @&gt; &#39;[{&quot;label&quot;:&quot;保单&quot;}]&#39; THEN &#39;0&#39; ELSE &#39;2&#39; END) as policy_upload_status,
   (SELECT CASE WHEN o.files @&gt; &#39;[{&quot;label&quot;:&quot;发票&quot;}]&#39; THEN &#39;0&#39; ELSE &#39;2&#39; END) as invoice_upload_status
from
   [{CC3A4415-79C6-496D-A1F0-8DEF0AF1BC61}=t_insurance_policy] i
   left join [{B375D6E7-4EF7-41DE-B66A-57F76DB6CA32}=t_order] o on  i.[{5558FA3A-CEF0-4306-8E30-6F75927A811D}=order_id] = o.[{351F78AA-7E21-45ED-B019-553119BD7ED5}=id]
   left join [{F6B53014-C8FA-4B78-B591-5382789963D9}=t_school] s on  o.[{1D71055A-FF1E-4F33-BF40-782502C17A53}=org_id] = s.[{21B46CAC-C314-4FB8-9277-6C40216606BB}=id]
   left join [{22E73830-9789-4D9D-8E01-BE6590BB8956}=t_user] u on  o.[{75D02749-B2D0-4B4D-9C66-5EE54DA4C4F8}=Insured_id] = u.[{805285D5-5233-43A6-82AE-E90BF3A2F5DC}=id]
   left join [{22E73830-9789-4D9D-8E01-BE6590BB8956}=t_user] h on  o.[{9A417382-A539-4A75-9FD3-E4FE9674A2C4}=Policyholder_id] = h.[{805285D5-5233-43A6-82AE-E90BF3A2F5DC}=id]
   left join [{61242374-7DF7-46F4-8B52-553207F51363}=t_xkb_user] x on  o.[{75D02749-B2D0-4B4D-9C66-5EE54DA4C4F8}=Insured_id] = x.[{6C0F6523-63C0-4006-AA33-DDBF51F4B1E1}=id]
   left join [{9CF854D7-F5C1-47CC-8AFF-24E7691D389E}=t_insurance_types] it on  i.[{9381165F-6C1D-448B-A146-9463FB924175}=insurance_type_id] = it.[{DEA82D77-B6D9-425B-922F-C0282E4C6A54}=id]
   left join [{D1FDC382-E8C1-48E3-BC77-8CA0A1FA0786}=t_insure_attach] a on  o.[{1D71055A-FF1E-4F33-BF40-782502C17A53}=org_id] = a.[{7A7EF400-8278-4A2B-9F26-CB987E42CF4C}=school_id] and o.[{B2EC4A21-E17A-4FD0-AC60-4C4E86598353}=batch] = a.[{1A059A0B-E9B5-4A18-95B4-113E7455895E}=batch] and x.[{951FA444-A2C0-4E81-AFE3-CDD51C64870E}=grade] = a.[{A9F592F1-16FD-47CE-B172-C99EC40A76D1}=grade] and a.[{3D79D3F2-E3D4-45FF-9B4B-891D28791705}=year] = i.[{C39037A7-A5C8-4310-8891-E309BCE1035B}=year]
where
   i.[{9381165F-6C1D-448B-A146-9463FB924175}=insurance_type_id] != 10040
   or o.[{106ECC0E-338C-461B-8536-71D20CEE7CF9}=charge_mode] != &#39;8&#39;
</a:TaggedSQLQuery>
