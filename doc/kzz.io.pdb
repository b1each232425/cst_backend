<a:View.SQLQuery> SELECT DISTINCT ON (practice_id, student_id) id,
    student_id,
    attempt,
    wrong_count,
    total_score,
    practice_id
   FROM v_student_practice_total_score
  ORDER BY practice_id, student_id, attempt DESC</a:View.SQLQuery>
<a:TaggedSQLQuery>select
   ON(practice_id, student_id) id,
   [{2F20940C-BC0B-45F4-AE25-1140B0E9DC55}=student_id],
   [{B37DFBC1-82E1-4C53-BA40-3DE41E9E1B0B}=attempt],
   [{D75201DC-6406-414F-B7D1-4EADC3827344}=wrong_count],
   [{5E02B38B-A756-4A8A-9BA5-5F83A8967050}=total_score],
   [{A1E28DB1-6CA5-4079-8617-A793FC152920}=practice_id]
from
   [{7241D126-B310-4EA0-9BFA-C3BB293C5A08}=v_student_practice_total_score]
order by
