   left join [{CC3A4415-79C6-496D-A1F0-8DEF0AF1BC61}=t_insurance_policy] i on  i.[{9076CC17-C92C-4EFE-9D8B-3D2839F7CD19}=id] = r.[{0AE3894C-6313-41B1-8004-1920A7B13B83}=insurance_policy_id]
   left join [{B375D6E7-4EF7-41DE-B66A-57F76DB6CA32}=t_order] o on  i.[{5558FA3A-CEF0-4306-8E30-6F75927A811D}=order_id] = o.[{351F78AA-7E21-45ED-B019-553119BD7ED5}=id]
   left join [{D1FDC382-E8C1-48E3-BC77-8CA0A1FA0786}=t_insure_attach] a on  CASE WHEN r.insurance_type_id = ANY (ARRAY[12002::bigint, 12004::bigint, 12006::bigint]) THEN o.org_id = a.school_id and o.[{B2EC4A21-E17A-4FD0-AC60-4C4E86598353}=batch] = a.[{1A059A0B-E9B5-4A18-95B4-113E7455895E}=batch] and b.[{951FA444-A2C0-4E81-AFE3-CDD51C64870E}=grade] = a.[{A9F592F1-16FD-47CE-B172-C99EC40A76D1}=grade] and a.[{3D79D3F2-E3D4-45FF-9B4B-891D28791705}=year] = i.year ELSE i.id = a.insure_policy_id END
