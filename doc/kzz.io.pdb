    ei.name as exam_name,
    ei.type as exam_type,
    ets.exam_session_id,
    ets.total_score,
    es.start_time,
    es.end_time,
    es.mark_mode,
    ep.id as exam_paper_id,
    ep.name as paper_name
   from [{8EA43941-8467-4280-A761-6CDAAC4D741A}=t_exam_info] ei
     JOIN [{068BEF97-5954-47D9-8905-5E26C30A27A6}=v_student_exam_total_score] ets on ei.[{B1D13A91-A4C9-4504-B545-856687C624A5}=id] = ets.[{A3B05B38-E081-47E7-B329-F596B573D75B}=exam_id]
