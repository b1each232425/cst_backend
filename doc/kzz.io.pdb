   ( SELECT                 CASE                     WHEN (( SELECT (floor(date_part(&#39;epoch&#39;::text, now())) * 1000::double precision)::bigint AS int8)) &gt; i.cease THEN ( SELECT &#39;已过期&#39;::text AS text)                     WHEN (( SELECT (floor(date_part(&#39;epoch&#39;::text, now())) * 1000::double precision)::bigint AS int8)) &lt; i.start THEN ( SELECT &#39;未起保&#39;::text AS text)                     ELSE ( SELECT &#39;保障中&#39;::text AS text)                 END::character varying AS text) as policy_status,
   it.[{21FC536F-84E9-4614-8720-0557493E936D}=parent_id] as insurance_type_parent_id,
   ( SELECT                 CASE                     WHEN it.parent_id = 10000 THEN ( SELECT it2.name                        FROM t_insurance_types it2                       WHERE it2.id = i.insurance_type_id)                     WHEN it.parent_id = 10040 THEN ( SELECT it2.name                        FROM t_insurance_types it2                       WHERE it2.id = 10040)                     ELSE ( SELECT o.insurance_type)                 END AS insurance_type) as insurance_display,
   o.[{106ECC0E-338C-461B-8536-71D20CEE7CF9}=charge_mode],
   o.[{3AD10A20-028F-483B-8F79-18445BADBDB5}=insurance_company],
   o.[{796B362D-88BF-4523-AB7F-6F676C61396E}=insurance_company_account],
   o.[{1B9AB4F2-3262-4C00-813E-9A87FCFB0DDD}=create_time] as order_create_time,
   o.[{FD79E108-82EB-43CD-98B6-17A615AE2307}=is_invoice],
   o.[{7D4CAAE3-C5DD-4DBE-9138-D6E8594305DD}=inv_borrow],
   o.[{4CE19CB7-CCC7-4155-B1BE-87FA8C4C937D}=inv_visible],
   o.[{E2098E0C-44F6-47D6-BCA3-1CF70724F0A2}=inv_title],
   o.[{10E0804A-4AD4-44D4-ADE8-EB54CA2BC7CE}=inv_status],
   o.[{6F1E8D74-490F-4A53-A60E-5DE42202803B}=files] as o_files,
   (SELECT CASE WHEN a.files @&gt; &#39;[{&quot;label&quot;:&quot;保单&quot;}]&#39; THEN &#39;0&#39; ELSE &#39;2&#39; END) as policy_upload_status,
   (SELECT CASE WHEN o.files @&gt; &#39;[{&quot;label&quot;:&quot;发票&quot;}]&#39; THEN &#39;0&#39; ELSE &#39;2&#39; END) as invoice_upload_status
from
   [{CC3A4415-79C6-496D-A1F0-8DEF0AF1BC61}=t_insurance_policy] i
   LEFT JOIN [{9CF854D7-F5C1-47CC-8AFF-24E7691D389E}=t_insurance_types] it on  i.[{9381165F-6C1D-448B-A146-9463FB924175}=insurance_type_id] = it.[{DEA82D77-B6D9-425B-922F-C0282E4C6A54}=id]
   LEFT JOIN [{B375D6E7-4EF7-41DE-B66A-57F76DB6CA32}=t_order] o on  i.[{5558FA3A-CEF0-4306-8E30-6F75927A811D}=order_id] = o.[{351F78AA-7E21-45ED-B019-553119BD7ED5}=id]
   LEFT JOIN [{61242374-7DF7-46F4-8B52-553207F51363}=t_xkb_user] x on  o.[{75D02749-B2D0-4B4D-9C66-5EE54DA4C4F8}=insured_id] = x.[{6C0F6523-63C0-4006-AA33-DDBF51F4B1E1}=id]
   LEFT JOIN [{D1FDC382-E8C1-48E3-BC77-8CA0A1FA0786}=t_insure_attach] a on  i.[{9076CC17-C92C-4EFE-9D8B-3D2839F7CD19}=id] = a.[{C5BE6E5C-2329-49A6-A69A-25CC02B8EB4F}=insure_policy_id]
where
   i.[{9381165F-6C1D-448B-A146-9463FB924175}=insurance_type_id] != 10040
   or o.[{106ECC0E-338C-461B-8536-71D20CEE7CF9}=charge_mode] = &#39;8&#39;
</a:TaggedSQLQuery>
