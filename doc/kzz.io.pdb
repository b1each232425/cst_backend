<a:View.SQLQuery> SELECT DISTINCT ON (practice_id, student_id) id AS submission_id,
    practice_id,
    student_id,
    attempt
   FROM t_practice_submissions
  WHERE ((status)::text = &#39;00&#39;::text)
  ORDER BY practice_id, student_id, attempt DESC;</a:View.SQLQuery>
<a:TaggedSQLQuery>select
   ON(practice_id, student_id) id as submission_id,
   [{FC48462E-E5EA-4612-B0D0-EB0CA75FF587}=practice_id],
   [{97DD3419-F145-4438-888C-83979043FFBD}=student_id],
   [{51EF5966-1B10-498D-931F-DC42088D621B}=attempt]
from
   [{001D64DC-4482-4769-BB38-330357BD47F2}=t_practice_submissions]
where
   (( [{05F00316-578B-437E-A620-E9060BABADDD}=status])
   ::text = &#39;00&#39;::text)
order by
   [{FC48462E-E5EA-4612-B0D0-EB0CA75FF587}=practice_id] ASC,
   [{97DD3419-F145-4438-888C-83979043FFBD}=student_id] ASC,
   attempt DESC; ASC
</a:TaggedSQLQuery>
