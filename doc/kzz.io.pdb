<o:View Id="o3036">
<a:ObjectID>068BEF97-5954-47D9-8905-5E26C30A27A6</a:ObjectID>
<a:Name>v_student_exam_total_score</a:Name>
<a:Code>v_student_exam_total_score</a:Code>
<a:CreationDate>1753948214</a:CreationDate>
<a:Creator>Zpekii</a:Creator>
<a:ModificationDate>1754640398</a:ModificationDate>
<a:Modifier>wzsaber</a:Modifier>
<a:Comment>学生考试成绩视图</a:Comment>
<a:EndScript>drop table if exists t_v_student_exam_total_score;
create table t_v_student_exam_total_score as select * from v_student_exam_total_score;</a:EndScript>
<a:View.SQLQuery> SELECT te.student_id,
    te.id AS examinee_id,
    te.exam_session_id,
    es.exam_id,
    e.name,
    e.submitted,
    es.start_time,
    es.end_time,
    sum(ta.answer_score) AS total_score,
    es.status
   FROM t_examinee te
     JOIN t_student_answers ta ON te.id = ta.examinee_id
     JOIN t_exam_session es ON te.exam_session_id = es.id
     JOIN t_exam_info e ON es.exam_id = e.id
  WHERE ta.type::text = &#39;00&#39;::text
  GROUP BY e.name, te.student_id, te.exam_session_id, es.exam_id, e.submitted, es.start_time, es.end_time, es.status, te.id;</a:View.SQLQuery>
<a:TaggedSQLQuery> select te.student_id,
    te.id as examinee_id,
    te.exam_session_id,
    es.exam_id,
    e.name,
    e.submitted,
    es.start_time,
    es.end_time,
    SUM(ta.answer_score) as total_score,
    es.status
   from [{131BAB2F-C6C5-4D6F-A37D-CE5E26A0D332}=t_examinee] te
     JOIN [{480D589B-C471-418D-9A14-F69DEDDF1777}=t_student_answers] ta on te.[{8010CF8B-921F-45ED-B921-65D01A7C345D}=id] = ta.[{B3B7AEC3-0147-474C-8B77-42A78F509AEB}=examinee_id]
     JOIN [{19981BAC-9978-46DF-B74F-ADD3B0CF8137}=t_exam_session] es on te.[{244CE7A6-81D7-4EFC-9C71-B437AFD089FF}=exam_session_id] = es.[{2A3C7F59-31BD-49C6-BDFC-9E105CD82CD1}=id]
     JOIN [{8EA43941-8467-4280-A761-6CDAAC4D741A}=t_exam_info] e on es.[{24947207-0D20-476C-967F-DBDEC131A18D}=exam_id] = e.[{B1D13A91-A4C9-4504-B545-856687C624A5}=id]
  where ta.type::text = &#39;00&#39;::text
