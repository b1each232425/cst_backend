<o:View Id="o1148">
<a:ObjectID>C49B9CDA-B411-4A1B-B9A0-26E2BFF425CC</a:ObjectID>
<a:Name>v_payment</a:Name>
<a:Code>v_payment</a:Code>
<a:CreationDate>1585041350</a:CreationDate>
<a:Creator>NUser</a:Creator>
<a:ModificationDate>1627361944</a:ModificationDate>
<a:Modifier>NUser</a:Modifier>
<a:EndScript>drop table if exists t_v_payment;
create table t_v_payment as select * from v_payment limit 1;</a:EndScript>
<a:View.SQLQuery>select pay.*,
       p.is_admin_pay,
       p.premium,
       p.third_party_premium,
       p.policyholder -&gt;&gt; &#39;Name&#39;::varchar as policyholder_name
from t_payment pay
left join t_insurance_policy p on pay.policy_no = p.sn and p.status = &#39;00&#39;;</a:View.SQLQuery>
<a:TaggedSQLQuery>select pay.*,
       p.is_admin_pay,
       p.premium,
       p.third_party_premium,
       p.policyholder -&gt;&gt; &#39;Name&#39;::varchar as policyholder_name
from [{73E5ED25-13FB-4614-A2DD-2D079141FA2C}=t_payment] pay
left join [{CC3A4415-79C6-496D-A1F0-8DEF0AF1BC61}=t_insurance_policy] p on pay.[{20AE67A9-F357-4E02-8280-70267B33D85B}=policy_no] = p.[{6DA83BA8-86DF-408D-A859-E5363498A486}=sn] and p.[{92CB69C1-33D0-485B-8321-DD3CAFDB694C}=status] = &#39;00&#39;;</a:TaggedSQLQuery>
<c:Columns>
<o:ViewColumn Id="o2799">
