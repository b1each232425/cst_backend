 m.endorsement_status,
 m.application_files,
 o.balance,
 o.balance_list,
 m.have_negotiated_price,
(select string_agg(p.sn,&#39;,&#39;) from t_insurance_policy p where p.order_id = m.order_id) as sn,
 
 m.policy_regen,
 m.clear_list,
 m.files_to_remove,
 
 o.policy_scheme original_policy_scheme,
