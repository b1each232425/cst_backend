<o:View Id="o1113">
<a:ObjectID>FE96FF90-940C-459E-BEC1-BAF7C48D1967</a:ObjectID>
<a:Name>v_insure_attach</a:Name>
<a:Code>v_insure_attach</a:Code>
<a:CreationDate>1575789119</a:CreationDate>
<a:Creator>冷翠崖竹</a:Creator>
<a:ModificationDate>1614570314</a:ModificationDate>
<a:Modifier>NUser</a:Modifier>
<a:Comment>保单附件视图，它实质是保单视图: v_insurance_policy</a:Comment>
<a:EndScript>drop table if exists t_v_insure_attach;
create table t_v_insure_attach as select * from v_insure_attach limit 1;</a:EndScript>
<a:View.SQLQuery>select
   insure_attach_id id,
   Org_ID,
   school,
   s_Category category,
   insurer,insurance_type,
   year,
   batch,
   Grade,
   files,
   policy_no,
   others,
   policy_upload_status,
   invoice_upload_status,
   attach_addi addi,
   attach_create_time create_time,
   attach_update_time update_time,
   attach_creator creator
from
   v_insurance_policy
where
   insurance_type_id = 10040
   and charge_mode != &#39;8&#39;
group by
   insure_attach_id,
   Org_ID,
   school,
   s_category,
   year,
   batch,
   grade,
   files,
   policy_no,
   others,
   insurer,insurance_type,
   policy_upload_status,
   invoice_upload_status,
   attach_addi,
   attach_create_time,
   attach_update_time,
   attach_creator
order by
   school ASC,
   year ASC,
   grade ASC,
   batch ASC</a:View.SQLQuery>
<a:TaggedSQLQuery>select
   [{C0870C87-AC17-4DF6-AF73-8E3AB3523B4E}=insure_attach_id] id,
   [{3DF8E666-7CB6-4342-A9C8-3D3BFA44796D}=Org_ID],
