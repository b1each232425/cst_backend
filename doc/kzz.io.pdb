<a:Name>v_domain_api</a:Name>
<a:Code>v_domain_api</a:Code>
<a:CreationDate>1583134421</a:CreationDate>
<a:Creator>NUser</a:Creator>
<a:ModificationDate>1615087138</a:ModificationDate>
<a:Modifier>NUser</a:Modifier>
<a:Comment>域,API</a:Comment>
<a:EndScript>drop table if exists t_v_domain_api;
create table if not exists t_v_domain_api as select * from v_domain_api limit 1;</a:EndScript>
<a:View.SQLQuery>select 
    da.id,
    d.id as auth_domain_id,
    d.name as domain_name,
    d.domain,d.priority,
    a.id as api_id,
    a.name as api_name,
    a.expose_path,
    a.access_control_level,
    da.domain_id, 
    da.grant_source,
    da.data_access_mode,
    da.data_scope,da.create_time,da.remark,da.addi,da.creator,da.status
from t_domain_api da
	join t_domain d on da.domain=d.id
	join t_api a on da.api=a.id
	order by d.id,a.id</a:View.SQLQuery>
<a:TaggedSQLQuery>select
   da.id,
   d.id as auth_domain_id,
   d.name as domain_name,
   d.domain,
   d.priority,
   a.id as api_id,
   a.name as api_name,
   a.expose_path,
   a.access_control_level,
   da.domain_id,
   da.grant_source,
   da.data_access_mode,
   da.data_scope,
   da.create_time,
   da.remark,
   da.addi,
   da.creator,
   da.status
from
   [{B8CEC14A-6240-4571-9362-7E1E33D8A5E7}=t_domain_api] da
   join [{1734E784-C560-40F1-ACEE-9AE71B0E7F21}=t_domain] d on  da.[{9BF70009-C8F0-4B07-BB3A-C3028E93184F}=domain] = d.[{9BD3BBC5-7CEB-4F80-BA22-64E543926467}=id]
   join [{9AC1CCFD-A09D-41D4-A251-9357CCBC3D0E}=t_api] a on  da.[{8DA7C15F-5F8A-4E80-A99C-4D7C874DFCF9}=api] = a.[{F3F9853C-2345-4E21-A5B4-B17CF463A232}=id]
order by
   d.[{9BD3BBC5-7CEB-4F80-BA22-64E543926467}=id] ASC,
   a.[{F3F9853C-2345-4E21-A5B4-B17CF463A232}=id] ASC
</a:TaggedSQLQuery>
