<o:Table Id="o101">
<a:ObjectID>163F5B3E-D48D-47D0-A088-7B1DECD4FC77</a:ObjectID>
<a:Name>t_domain_asset</a:Name>
<a:Code>t_domain_asset</a:Code>
<a:CreationDate>1721611384</a:CreationDate>
<a:Creator>NUser</a:Creator>
<a:ModificationDate>1721735230</a:ModificationDate>
<a:Modifier>NUser</a:Modifier>
<a:Comment>define

user domain relation
domain api relation
other relation</a:Comment>
<a:EndScript>with cte as ( select id,domain,name from t_domain )
insert into t_domain_asset(r_type, domain_id,asset_id)
select &#39;ud&#39;,cte.id,u.id
from t_user u join cte on u.category=cte.domain
on conflict do nothing;</a:EndScript>
<a:TotalSavingCurrency/>
