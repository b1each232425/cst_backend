   left join [{61242374-7DF7-46F4-8B52-553207F51363}=t_xkb_user] b on  u.[{805285D5-5233-43A6-82AE-E90BF3A2F5DC}=id] = b.[{6C0F6523-63C0-4006-AA33-DDBF51F4B1E1}=id]
