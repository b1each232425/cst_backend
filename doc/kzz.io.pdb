<o:View Id="o1115">
<a:ObjectID>7555DE68-9799-4E54-B10C-E788ABE8F088</a:ObjectID>
<a:Name>v_mistake_correct</a:Name>
<a:Code>v_mistake_correct</a:Code>
<a:CreationDate>1575789119</a:CreationDate>
<a:Creator>冷翠崖竹</a:Creator>
<a:ModificationDate>1627361996</a:ModificationDate>
<a:Modifier>NUser</a:Modifier>
<a:Comment>报错视图</a:Comment>
<a:EndScript>drop table if exists t_v_mistake_correct;
create table t_v_mistake_correct as select * from v_mistake_correct limit 1;



</a:EndScript>
<a:View.SQLQuery>select
m.id,
order_id,

o.org_id,
o.commence_date,
o.expiry_date,
o.insurance_type,

m.official_name,
m.id_card_type,
m.id_card_no,
m.gender,
m.birthday,

x.school,
x.school_id,
x.school_type,

o.insured_id,
x.official_name  original_official_name ,
x.id_card_type	 original_id_card_type,  
x.id_card_no		 original_id_card_no,    
x.gender				 original_gender,        
x.birthday			 original_birthday,      

m.official_name_p,
m.id_card_type_p,
m.id_card_no_p,
m.gender_p,
m.birthday_p,

o.policyholder_id,
u.official_name original_official_name_p ,
u.id_card_type 	original_id_card_type_p,  
u.id_card_no 		original_id_card_no_p,    
u.gender 				original_gender_p,        
u.birthday			original_birthday_p,

m.addi,
m.create_time,
m.update_time,
m.creator,
m.remark,
m.status

from t_mistake_correct m
join t_order o on o.id=m.order_id
left join v_xkb_user x on x.id=o.insured_id
left join t_user u on o.policyholder_id = u.id

</a:View.SQLQuery>
<a:TaggedSQLQuery>select
   m.id,
   [{D56C4CB2-CB43-4F58-887A-81D87FD29EDC}=order_id],
   o.org_id,
   o.commence_date,
   o.expiry_date,
   o.insurance_type,
   m.official_name,
   m.id_card_type,
   m.id_card_no,
   m.gender,
   m.birthday,
   x.school,
   x.school_id,
   x.school_type,
   o.insured_id,
   x.official_name original_official_name,
   x.id_card_type original_id_card_type,
   x.id_card_no original_id_card_no,
   x.gender original_gender,
   x.birthday original_birthday,
   m.official_name_p,
   m.id_card_type_p,
   m.id_card_no_p,
   m.gender_p,
   m.birthday_p,
   o.policyholder_id,
   u.official_name original_official_name_p,
   u.id_card_type original_id_card_type_p,
   u.id_card_no original_id_card_no_p,
   u.gender original_gender_p,
   u.birthday original_birthday_p,
   m.addi,
   m.create_time,
   m.update_time,
   m.creator,
   m.remark,
   m.status
from
   [{72075A45-5620-4ED4-9493-A7B2B59F71CD}=t_mistake_correct] m
   join [{B375D6E7-4EF7-41DE-B66A-57F76DB6CA32}=t_order] o on  o.[{351F78AA-7E21-45ED-B019-553119BD7ED5}=id] = m.[{D56C4CB2-CB43-4F58-887A-81D87FD29EDC}=order_id]
   left join [{1C8C9BB6-C574-4EDC-B5A3-3222727EEA19}=v_xkb_user] x on  x.[{D7DFC368-0AAF-4043-860B-0D14A86EAD0F}=id] = o.[{75D02749-B2D0-4B4D-9C66-5EE54DA4C4F8}=insured_id]
   left join [{22E73830-9789-4D9D-8E01-BE6590BB8956}=t_user] u on  o.[{9A417382-A539-4A75-9FD3-E4FE9674A2C4}=policyholder_id] = u.[{805285D5-5233-43A6-82AE-E90BF3A2F5DC}=id]
</a:TaggedSQLQuery>
