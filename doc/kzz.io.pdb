   it.parent_id as insurance_type_parent_id,
   ( SELECT                 CASE                     WHEN it.parent_id = 10000 THEN ( SELECT it2.name                        FROM t_insurance_types it2                       WHERE it2.id = i.insurance_type_id)                     WHEN it.parent_id = 10040 THEN ( SELECT it2.name                        FROM t_insurance_types it2                       WHERE it2.id = 10040)                     ELSE ( SELECT o.insurance_type)                 END AS insurance_type) as insurance_display,
