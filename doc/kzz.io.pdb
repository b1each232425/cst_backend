<a:View.SQLQuery>SELECT p.id                                       AS practice_id,
       COALESCE(count(DISTINCT ps.id), 0::bigint) AS unmarked_count
FROM t_practice p
         LEFT JOIN t_practice_submissions ps ON ps.practice_id = p.id AND ps.status::text = &#39;06&#39;::text
GROUP BY p.id;</a:View.SQLQuery>
<a:TaggedSQLQuery>select p.id                                       as practice_id,
       COALESCE(count(DISTINCT ps.id), 0::bigint) as unmarked_count
from [{F6063EF0-FEE9-4FEC-A10C-5340AC0880B4}=t_practice] p
         LEFT JOIN [{001D64DC-4482-4769-BB38-330357BD47F2}=t_practice_submissions] ps on ps.[{FC48462E-E5EA-4612-B0D0-EB0CA75FF587}=practice_id] = p.[{946B9FDD-6EBD-46E2-9976-AE9FB3BDBF4F}=id] AND ps.status::text = &#39;06&#39;::text
group by p.id;</a:TaggedSQLQuery>
