		"filesize": "^11.0.2",
		"hash-wasm": "^4.12.0",
		"is-stream": "^2.0.1",
		"js-base64": "^3.7.8",
		"lodash.throttle": "^4.1.1",
		"proper-lockfile": "^4.1.2",
		"url-parse": "^1.5.10"
	}
